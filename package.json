{
  "name": "keebhoarder",
  "private": true,
  "useWorkspaces": true,
  "devDependencies": {
    "lerna": "^3.14.1",
    "print-message": "^3.0.1"
  },
  "scripts": {
    "prepare": "node ./sup-keeblord.js",
    "keeb": "lerna exec --stream -- yarn start",
    "web": "cd ./packages/web && yarn start",
    "graph": "cd ./packages/graph && yarn start",
    "lerna-wizard": "npx lerna-wizard",
    "test-web": "lerna exec --stream -- yarn test"
  },
  "gitHooks": {
    "pre-push": "yarn test-web"
  }
}
