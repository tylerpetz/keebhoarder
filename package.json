    "eslint-plugin-promise": "^4.2.1",
    "eslint-plugin-standard": "^5.0.0",
    "eslint-plugin-vue": "^7.4.0",
    "lint-staged": "^10.2.11",
    "mini-css-extract-plugin": "^1.3.2",
    "postcss": "^7",
    "read-css": "^0.3.0",
    "sass": "^1.26.10",
    "sass-loader": "^10.1.0",
